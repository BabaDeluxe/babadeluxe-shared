#!/bin/sh
set -e

# Capture originally staged files
ORIG_STAGED="$(git diff --cached --name-only)"

# Generate barrels
npm run generate-barrels || { echo "❌ Barrel generation failed"; exit 1; }

# Format
npm run format

# Re-stage originally staged files (handles modifications AND deletions)
if [ -n "$ORIG_STAGED" ]; then
  echo "$ORIG_STAGED" | xargs git add --all --
fi

# Add newly created barrel files
git ls-files -o --exclude-standard -- 'src/**/index.ts' | xargs -r git add

exit 0
