#!/bin/bash

# Store the original commit message
COMMIT_MSG_FILE="$GIT_DIR/COMMIT_EDITMSG"
if [ -f "$COMMIT_MSG_FILE" ]; then
  COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
else
  COMMIT_MSG=""
fi

# Capture the list of originally staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Check if any .ts files in src/ changed (excluding index.ts barrel files)
if echo "$STAGED_FILES" | grep -q "^src/.*\.ts$" | grep -v "index\.ts$"; then
  echo "Source files changed, regenerating barrel files..."
  npm run generate-barrels

  # Stage the updated barrel files
  git add "**/index.ts"
fi

# Format JavaScript code
npm run format

# Only re-stage the files that were originally staged (if they were modified by formatting)
if [ -n "$STAGED_FILES" ]; then
  echo "$STAGED_FILES" | xargs git add

  # Reapply the original commit message
  if [ -n "$COMMIT_MSG" ]; then
    echo "$COMMIT_MSG" > "$COMMIT_MSG_FILE"
  fi
fi
