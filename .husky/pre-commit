#!/bin/sh
set -ex

ORIG_STAGED="$(git diff --cached --name-only)"

npm run generate-barrels || { echo "❌ Barrel generation failed"; exit 1; }
npm run format

# Re-add each file individually, properly quoted
if [ -n "$ORIG_STAGED" ]; then
  echo "$ORIG_STAGED" | while IFS= read -r file; do
    if [ -f "$file" ]; then
      git add "$file"
    else
      git add -u "$file"
    fi
  done
fi

# Add new barrels
git ls-files -o --exclude-standard -- 'src/**/index.ts' | xargs -r git add

exit 0
