#!/bin/sh
set -e

ORIG_STAGED="$(git diff --cached --name-only)"

npm run generate-barrels || { echo "❌ Barrel generation failed"; exit 1; }
npm run format

# Re-stage originally staged files that still exist
if [ -n "$ORIG_STAGED" ]; then
  echo "$ORIG_STAGED" | while IFS= read -r file; do
    if [ -f "$file" ]; then
      git add "$file"
    fi
  done
fi

# Add ALL barrel files (new AND modified)
find src -name "index.ts" -type f -exec git add {} +

exit 0
