{
  "name": "@babadeluxe/shared",
  "version": "0.20.3",
  "author": "simwai",
  "keywords": [
    "ts"
  ],
  "description": "Shared code of BabaDeluxe",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist",
    "package.json",
    "LICENSE.md",
    "README.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./generated-socket-types": {
      "types": "./dist/generated-socket-types/index.d.ts",
      "import": "./dist/generated-socket-types/index.mjs",
      "require": "./dist/generated-socket-types/index.cjs"
    },
    "./settings": {
      "types": "./dist/settings/index.d.ts",
      "import": "./dist/settings/index.mjs",
      "require": "./dist/settings/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.cjs"
    }
  },
  "scripts": {
    "format": "xo --fix --prettier",
    "generate-barrels": "barrelsby --config ./.barrelsby.json",
    "build": "unbuild",
    "test-package": "npm pack --dry-run",
    "publish-patch": "tsx ./publish.ts patch",
    "publish-minor": "tsx ./publish.ts minor",
    "publish-major": "tsx ./publish.ts major",
    "prepare": "husky"
  },
  "dependencies": {
    "@types/dotenv": "^8.2.3",
    "dotenv": "^17.4.0",
    "neverthrow": "^8.2.0",
    "socket.io-client": "^4.7.4",
    "zod": "^4.1.12",
    "zod-sockets": "^5.0.0"
  },
  "devDependencies": {
    "@babadeluxe/xo-config": "^0.4.10",
    "@sindresorhus/tsconfig": "^8.1.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "barrelsby": "^2.8.1",
    "baseline-browser-mapping": "^2.9.8",
    "eslint": "^9.38.0",
    "husky": "^9.1.7",
    "socket.io": "^4.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "unbuild": "^3.6.1",
    "xo": "^1.2.2"
  },
  "publishConfig": {
    "registry": "https://npflared.simonwaiblinger.workers.dev"
  }
}
