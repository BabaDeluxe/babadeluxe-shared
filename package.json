{
  "name": "@babadeluxe/shared",
  "version": "0.1.13",
  "author": "simwai",
  "keywords": [
    "ts"
  ],
  "description": "Shared code of babadeluxe including types and constants.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./constants/*": {
      "types": "./dist/constants/*.d.ts",
      "import": "./dist/constants/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js"
    },
    "./validators/*": {
      "types": "./dist/validators/*.d.ts",
      "import": "./dist/validators/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "constants/*": [
        "./dist/constants/*.d.ts"
      ],
      "types/*": [
        "./dist/types/*.d.ts"
      ],
      "validators/*": [
        "./dist/validators/*.d.ts"
      ]
    }
  },
  "scripts": {
    "format": "xo --fix --prettier",
    "prebuild": "npx rimraf -g ./dist/** && barrelsby --config ./.barrelsby.json",
    "build": "npm run prebuild && npm run build-only",
    "build-only": "tsc",
    "test-package": "npm pack --dry-run",
    "publish-patch": "npm run build && npm version patch && npm publish",
    "publish-minor": "npm run build && npm version minor && npm publish",
    "publish-major": "npm run build && npm version major && npm publish",
    "prepare": "husky"
  },
  "dependencies": {
    "yup": "^1.7.0"
  },
  "devDependencies": {
    "@babadeluxe/xo-config": "^0.1.26",
    "@sindresorhus/tsconfig": "^8.0.1",
    "barrelsby": "^2.8.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "rimraf": "^6.0.1",
    "socket.io": "^4.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "xo": "^1.2.2"
  }
}
